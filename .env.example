# Copia este archivo como .env y rellena los valores reales
# El .env NUNCA se sube al repositorio (está en .gitignore)

# PostgreSQL
POSTGRES_DB=nombre_de_tu_db
POSTGRES_USER=usuario_postgres
POSTGRES_PASSWORD=password_seguro

# API Key para proteger el endpoint MCP (genérala con openssl o PowerShell)
MCP_API_KEY=pon-aqui-tu-api-key

# Mismo JWT secret que usa el WebApi
JWT_SECRET=pon-aqui-tu-jwt-secret
